# Configuración del Entorno - Work Life OS

# --- SUPABASE ---
# URL pública de tu instancia de Supabase
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
# Key pública anon (segura para usar en el navegador)
NEXT_PUBLIC_SUPABASE_ANON_KEY=...
# Key de servicio (SOLO PARA EL SERVIDOR)
SUPABASE_SERVICE_ROLE_KEY=...

# --- STRIPE ---
# Secret Key de Stripe para procesamiento de pagos
STRIPE_SECRET_KEY=sk_live_...
# Secret de Webhook (obligatorio para procesar eventos)
STRIPE_WEBHOOK_SECRET=whsec_...

# --- EMAIL (RESEND) ---
# Key para el envío de notificaciones y facturas
RESEND_API_KEY=re_...

# --- INTELIGENCIA ARTIFICIAL ---
# API Key de Groq para el análisis de nóminas con Llama 3
GROQ_API_KEY=gsk_...

# --- MONITOREO ---
# Sentry DSN para reporte de errores en producción
NEXT_PUBLIC_SENTRY_DSN=...

# --- ENTORNO ---
# Dominio base para redirecciones y sitemaps
BASE_URL=https://work-life-os.olianlabs.com
